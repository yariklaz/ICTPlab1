@model IEnumerable<QuestBooking.Domain.Model.Promocode>

@{
    ViewData["Title"] = "Промокоди";
}

<style>
    /* Темне скло для картки */
    .promo-card {
        background: rgba(20, 20, 30, 0.6);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .table {
        color: #e0e0e0;
    }

        .table thead th {
            background-color: rgba(0,0,0,0.2);
            color: var(--neon-accent, #00f3ff);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            padding-top: 15px;
            padding-bottom: 15px;
        }

        .table tbody tr {
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .table tbody td {
            border-bottom: none;
        }

    /* Неоновий купон */
    .promo-code-badge {
        font-family: monospace;
        font-size: 1.1rem;
        letter-spacing: 2px;
        background: rgba(0, 243, 255, 0.1);
        border: 1px dashed var(--neon-accent, #00f3ff);
        color: var(--neon-accent, #00f3ff);
        padding: 5px 15px;
        border-radius: 8px;
        font-weight: bold;
        text-shadow: 0 0 5px rgba(0, 243, 255, 0.5);
    }

    .discount-circle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 45px;
        height: 45px;
        background: rgba(0, 255, 136, 0.1);
        color: #00ff88;
        border: 1px solid rgba(0, 255, 136, 0.3);
        border-radius: 50%;
        font-weight: 800;
        font-size: 1.1rem;
        text-shadow: 0 0 8px rgba(0, 255, 136, 0.4);
    }

    /* Стилізовані кнопки дій */
    .action-btn {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #fff;
    }

        .action-btn:hover {
            background: rgba(255, 255, 255, 0.1);
            color: #fff;
        }
</style>

<div class="container mt-4 mb-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold mb-0 text-white">Промокоди</h2>
            <p class="small mb-0 mt-1" style="color: #a0a0a0;">Керування знижками та спеціальними пропозиціями</p>
        </div>
        <a asp-action="Create" class="btn shadow-sm rounded-pill px-4 fw-bold" style="background: var(--neon-accent, #00f3ff); color: #000;">
            <i class="bi bi-plus-lg me-1"></i> Новий промокод
        </a>
    </div>

    <div class="card promo-card overflow-hidden">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Код знижки</th>
                        <th class="text-center">Розмір знижки</th>
                        <th>Період дії</th>
                        <th>Статус</th>
                        <th class="text-end pe-4">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5" style="color: #666;">
                                <i class="bi bi-tag display-4 d-block mb-3 opacity-25"></i>
                                Ви ще не створили жодного промокоду.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.OrderByDescending(p => p.Id))
                        {
                            bool isActive = item.ValidFrom <= DateTime.Now && item.ValidTo >= DateTime.Now;
                            bool isExpired = item.ValidTo < DateTime.Now;
                            bool isFuture = item.ValidFrom > DateTime.Now;

                            <tr>
                                <td class="ps-4 py-3">
                                    <span class="promo-code-badge">@item.Code</span>
                                </td>
                                <td class="text-center">
                                    <div class="discount-circle" title="Знижка @item.DiscountPercent%">
                                        -@item.DiscountPercent<small>%</small>
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-medium text-white">
                                        @item.ValidFrom.ToString("dd.MM.yyyy") — @item.ValidTo.ToString("dd.MM.yyyy")
                                    </div>
                                    <div class="small" style="color: #888;">
                                        @(Math.Ceiling((item.ValidTo - DateTime.Now).TotalDays)) днів залишилось
                                    </div>
                                </td>
                                <td>
                                    @if (isActive)
                                    {
                                        <span class="badge rounded-pill px-3 py-2" style="background: rgba(0, 255, 136, 0.15); border: 1px solid #00ff88; color: #00ff88;">
                                            <i class="bi bi-check-circle-fill me-1"></i> Активний
                                        </span>
                                    }
                                    else if (isExpired)
                                    {
                                        <span class="badge rounded-pill px-3 py-2" style="background: rgba(255, 71, 87, 0.15); border: 1px solid #ff4757; color: #ff4757;">
                                            <i class="bi bi-x-circle-fill me-1"></i> Минув
                                        </span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm rounded-pill">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm action-btn"><i class="bi bi-pencil-square"></i></a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm action-btn"><i class="bi bi-info-circle"></i></a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm action-btn text-danger"><i class="bi bi-trash3"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>