@model QuestBooking.Domain.Model.Booking

@{
    ViewData["Title"] = "Бронювання квесту";
    // Отримуємо обрану дату з ViewBag, щоб календар не "забував" її після перезавантаження
    var currentDateStr = ViewBag.SelectedDate ?? DateTime.Today.ToString("yyyy-MM-dd");
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2 class="mb-4">Бронювання квесту</h2>

            <form asp-action="Create" method="post" class="card shadow p-4 bg-white">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <input type="hidden" id="questroomId" name="questroomId" value="@ViewBag.QuestroomId" />
                <div class="form-group mb-3">
                    <label class="control-label fw-bold mb-1">Ваше ім'я</label>
                    <input type="text" name="clientName" class="form-control" placeholder="Введіть ім'я" required />
                </div>

                <div class="form-group mb-3">
                    <label class="control-label fw-bold mb-1">Номер телефону</label>
                    <input type="tel" name="clientPhone" class="form-control"
                           placeholder="+380..."
                           pattern="^(\+38)?0[0-9]{9}$"
                           title="Введіть номер у форматі 0XXXXXXXXX або +380XXXXXXXXX" required />
                </div>

                <div class="form-group mb-4">
                    <label class="control-label fw-bold mb-1">Email (для відправки квитків)</label>
                    <input type="email" name="clientEmail" class="form-control" placeholder="example@gmail.com" />
                </div>

                <div class="form-group mb-3">
                    <label class="control-label text-info fw-bold">Дата гри</label>
                    <input type="text" id="bookingDate" name="BookingDate" class="form-control my-datepicker" value="@currentDateStr" required />
                </div>

                <div class="form-group mb-4">
                    <label class="control-label fw-bold mb-1">Доступний час на @currentDateStr</label>

                    @if (ViewBag.SlotId != null && ((SelectList)ViewBag.SlotId).Any())
                    {
                        <select asp-for="SlotId" class="form-select form-control border-primary" asp-items="ViewBag.SlotId" required>
                            <option value="">-- Оберіть зручний час --</option>
                        </select>
                    }
                    else
                    {
                        <input type="text" class="form-control bg-light text-muted" value="На цю дату вільних годин немає" disabled />
                        <input type="hidden" asp-for="SlotId" value="" />
                    }
                </div>

                <div class="form-group mb-4">
                    <label class="control-label fw-bold mb-1">Промокод (необов'язково)</label>
                    <input type="text" name="enteredPromoCode" class="form-control" placeholder="Введіть промокод" />
                </div>

                <div class="d-grid mt-4">
                    <input type="submit" value="Підтвердити бронювання" class="btn btn-success btn-lg shadow-sm" />
                </div>
            </form>

            <div class="mt-3 text-center">
                <a asp-controller="Questrooms" asp-action="Index" class="btn btn-link text-secondary">← Повернутися до списку квестів</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            flatpickr(".my-datepicker", {
                locale: "uk",
                minDate: "today",
                dateFormat: "Y-m-d",
                disableMobile: "true",
                // Встановлюємо дату, яка прийшла з сервера
                defaultDate: "@currentDateStr",
                onChange: function(selectedDates, dateStr, instance) {
                    // Перевіряємо, чи дата дійсно змінилася, щоб уникнути зайвих перезавантажень
                    if (dateStr !== "@currentDateStr") {
                        var roomId = document.getElementById('questroomId').value;
                        // Перезавантажуємо сторінку з обраною датою
                        window.location.href = '/Bookings/Create?questroomId=' + roomId + '&bookingDate=' + dateStr;
                    }
                }
            });
        });
    </script>
}